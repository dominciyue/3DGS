# Copy to .env and edit. All values are optional — defaults run in mock mode.

# --- pipeline mode ---
# 1 = synthetic outputs, no GPU/tools (default). 0 = run real COLMAP / 3DGS.
PIPELINE_MOCK=1
# Per-step delay (seconds) in mock mode so the UI shows progress.
MOCK_STAGE_DELAY=0.3
# Per-stage retry attempts on failure.
STAGE_MAX_RETRIES=1
# Where job working dirs live (default: backend/data).
# DATA_DIR=/abs/path/to/data

# --- Agent (LLM) ---
# Leave unset to use the deterministic MockPlanner. Set to enable Claude planning.
# ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-opus-4-7

# --- external tools (only needed when PIPELINE_MOCK=0) ---
COLMAP_BIN=colmap
# GS_REPO_DIR=../third_party/gaussian-splatting
# GS_PYTHON=/path/to/conda/envs/gaussian_splatting/bin/python
# MIP_REPO_DIR=../third_party/mip-splatting
# DGS2_REPO_DIR=../third_party/2d-gaussian-splatting
# RELIGHT_REPO_DIR=../third_party/Relightable3DGaussian

# --- server ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000
